# FindTorchGCU
# -------
#
# Finds the TorchGCU library
#
# This will define the following variables:
#
# TORCH_GCU_FOUND        -- True if the system has the Torch library
# TORCH_GCU_INCLUDE_DIRS -- The include directories for torch_gcu
# TORCH_GCU_LIBRARIES    -- Libraries to link against
# TORCH_GCU_CXX_FLAGS    -- Additional (required) compiler flags
#

include(FindPackageHandleStandardArgs)

if(DEFINED ENV{TORCH_GCU_INSTALL_PREFIX})
  set(TORCH_GCU_INSTALL_PREFIX $ENV{TORCH_GCU_INSTALL_PREFIX})
else()
  # Assume we are in <install-prefix>/share/cmake/TorchGCU/TorchGCUConfig.cmake
  get_filename_component(CMAKE_CURRENT_LIST_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
  get_filename_component(TORCH_GCU_INSTALL_PREFIX "${CMAKE_CURRENT_LIST_DIR}/../../../" ABSOLUTE)
endif()

if(EXISTS "${TORCH_GCU_INSTALL_PREFIX}")
  set(TORCH_GCU_FOUND 1)
else()
  message(FATAL_ERROR "Cannot find installed TorchGCU directory")
endif()

# Include directories.
if(EXISTS "${TORCH_GCU_INSTALL_PREFIX}/include")
  set(TORCH_GCU_INCLUDE_DIRS
    ${TORCH_GCU_INSTALL_PREFIX}/include)
else()
  message(FATAL_ERROR "Cannot find installed TorchGCU include directory")
endif()

include_directories(${TORCH_GCU_INCLUDE_DIRS})
include_directories(/opt/tops/include)
include_directories(/usr/include/gcu/)

# Library directories.
if(EXISTS "${TORCH_GCU_INSTALL_PREFIX}/lib")
  set(TORCH_GCU_LIBRARIES
    ${TORCH_GCU_INSTALL_PREFIX}/lib/libtorch_gcu.so)
else()
  message(FATAL_ERROR "Cannot find installed TorchGCU library directory")
endif()

# When we build libtorch_gcu with the old libstdc++ ABI, dependent libraries must too.
if(CMAKE_SYSTEM_NAME STREQUAL "Linux")
  set(TORCH_GCU_CXX_FLAGS "-D_GLIBCXX_USE_CXX11_ABI=@_GLIBCXX_USE_CXX11_ABI@")
endif()
